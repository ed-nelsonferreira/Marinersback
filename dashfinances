<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recife Mariners - Gestão Integral 2026</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800&family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        :root {
            --mariners-navy: #09162E;
            --mariners-navy-light: #0E1F42;
            --mariners-cyan: #3DB8E8;
            --mariners-green: #22D07A;
            --mariners-red: #F04F4F;
            --mariners-amber: #F5A623;
            --mariners-purple: #8B5CF6;
        }

        body {
            font-family: 'Barlow', sans-serif;
            background-color: #050B18;
            color: #E2E8F0;
        }

        h1, h2, h3, .font-condensed {
            font-family: 'Barlow Condensed', sans-serif;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .sidebar-active {
            background: linear-gradient(90deg, rgba(61, 184, 232, 0.15) 0%, transparent 100%);
            border-left: 4px solid var(--mariners-cyan);
            color: var(--mariners-cyan);
        }

        .glass-card {
            background: rgba(14, 31, 66, 0.6);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(61, 184, 232, 0.1);
            border-radius: 12px;
        }

        .status-badge {
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 9px;
            font-weight: 800;
            text-transform: uppercase;
        }

        .st-ok { background: rgba(34, 208, 122, 0.15); color: var(--mariners-green); border: 1px solid rgba(34, 208, 122, 0.3); }
        .st-nok { background: rgba(240, 79, 79, 0.15); color: var(--mariners-red); border: 1px solid rgba(240, 79, 79, 0.3); }
        .st-neg { background: rgba(245, 166, 35, 0.15); color: var(--mariners-amber); border: 1px solid rgba(245, 166, 35, 0.3); }
        .st-novo { background: rgba(167, 139, 250, 0.15); color: #A78BFA; border: 1px solid rgba(167, 139, 250, 0.3); }

        .pos-tag {
            background: rgba(61, 184, 232, 0.1);
            color: var(--mariners-cyan);
            border: 1px solid rgba(61, 184, 232, 0.2);
            padding: 1px 5px;
            border-radius: 3px;
            font-size: 9px;
            font-weight: 800;
        }

        .chart-container {
            height: 250px;
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 8px;
            padding-bottom: 5px;
        }

        .chart-bar-group {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            height: 100%;
        }

        .bar-plan { background-color: var(--mariners-cyan); opacity: 0.8; width: 100%; border-radius: 2px 2px 0 0; }
        .bar-taxa { background-color: var(--mariners-purple); opacity: 0.8; width: 100%; border-radius: 2px 2px 0 0; }
        .bar-past { background-color: var(--mariners-green); opacity: 0.6; width: 100%; border-radius: 2px 2px 0 0; }

        .tab-content { display: none; }
        .tab-content.active { display: block; animation: fadeIn 0.3s ease; }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #050B18; }
        ::-webkit-scrollbar-thumb { background: #1C3470; border-radius: 10px; }

        .sparkle-btn {
            background: linear-gradient(45deg, #3DB8E8, #8B5CF6);
            transition: all 0.3s ease;
        }
        .sparkle-btn:hover {
            box-shadow: 0 0 15px rgba(139, 92, 246, 0.5);
            transform: translateY(-1px);
        }

        #ai-modal {
            background: rgba(5, 11, 24, 0.9);
            backdrop-filter: blur(12px);
        }

        .loader {
            border: 3px solid rgba(255,255,255,0.1);
            border-top: 3px solid var(--mariners-cyan);
            border-radius: 50%;
            width: 24px;
            height: 24px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        .filter-btn-active {
            background-color: var(--mariners-cyan) !important;
            color: var(--mariners-navy) !important;
        }

        select.filter-select {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%233DB8E8' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
            background-position: right 0.5rem center;
            background-repeat: no-repeat;
            background-size: 1.5em 1.5rem;
            padding-right: 2.5rem;
            -webkit-appearance: none;
            -moz-appearance: none;
            appearance: none;
        }
    </style>
</head>
<body class="flex h-screen overflow-hidden">

    <!-- AI Response Modal -->
    <div id="ai-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-6">
        <div class="glass-card w-full max-w-2xl p-8 border-2 border-[#3DB8E8]/30 shadow-2xl flex flex-col max-h-[85vh]">
            <div class="flex justify-between items-center mb-6">
                <div class="flex items-center gap-3">
                    <i class="fa-solid fa-wand-magic-sparkles text-2xl text-[#3DB8E8]"></i>
                    <h3 class="text-xl font-bold font-condensed tracking-wider uppercase">Assistente ✨ Mariners AI</h3>
                </div>
                <button onclick="closeAIModal()" class="text-slate-500 hover:text-white transition-colors text-xl">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div id="ai-content" class="flex-1 overflow-y-auto text-slate-300 space-y-4 leading-relaxed whitespace-pre-line pr-2"></div>
            <div class="mt-6 pt-4 border-t border-white/5 flex justify-between items-center">
                <button onclick="copyAIText()" class="text-[10px] font-bold text-[#3DB8E8] uppercase hover:underline flex items-center gap-2">
                    <i class="fa-solid fa-copy"></i> Copiar Texto
                </button>
                <p class="text-[9px] text-slate-600 font-bold uppercase tracking-widest italic">Elite Management AI</p>
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <aside class="w-64 bg-[#09162E] border-r border-white/5 flex flex-col z-20 shrink-0">
        <div class="p-8">
            <div class="flex items-center gap-3">
                <i class="fa-solid fa-anchor text-3xl text-[#3DB8E8]"></i>
                <h1 class="text-xl font-bold tracking-tighter text-white">MARINERS <span class="text-[#3DB8E8]">HUB</span></h1>
            </div>
            <p class="text-[9px] text-slate-500 tracking-[3px] uppercase mt-2 font-bold">Recife Mariners FA</p>
        </div>

        <nav class="flex-1 px-4 space-y-1 overflow-y-auto">
            <button onclick="switchTab('dashboard')" class="tab-btn sidebar-active w-full flex items-center px-4 py-3 text-sm font-semibold rounded-lg transition-all" id="btn-dashboard">
                <i class="fa-solid fa-gauge-high w-6"></i> Visão Geral
            </button>
            <button onclick="switchTab('atletas')" class="tab-btn w-full flex items-center px-4 py-3 text-sm font-semibold text-slate-400 hover:text-white rounded-lg transition-all" id="btn-atletas">
                <i class="fa-solid fa-users w-6"></i> Elenco (46)
            </button>
            <button onclick="switchTab('financeiro')" class="tab-btn w-full flex items-center px-4 py-3 text-sm font-semibold text-slate-400 hover:text-white rounded-lg transition-all" id="btn-financeiro">
                <i class="fa-solid fa-chart-line w-6"></i> Projeção Mensal
            </button>
            <button onclick="switchTab('pagamentos')" class="tab-btn w-full flex items-center px-4 py-3 text-sm font-semibold text-slate-400 hover:text-white rounded-lg transition-all" id="btn-pagamentos">
                <i class="fa-solid fa-money-bill-transfer w-6"></i> Liquidação
            </button>
        </nav>

        <div class="p-6 border-t border-white/5 bg-black/20 space-y-4">
            <button onclick="generateStrategicInsights()" class="sparkle-btn w-full py-2.5 rounded-lg flex items-center justify-center gap-2 text-[10px] font-bold text-white uppercase tracking-widest shadow-lg">
                <i class="fa-solid fa-wand-magic-sparkles"></i> ✨ Insights IA
            </button>
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-[#3DB8E8] flex items-center justify-center text-[#09162E] font-extrabold text-xs">N</div>
                <div>
                    <p class="text-xs font-bold text-white uppercase">Nelsinho</p>
                    <p class="text-[9px] text-slate-500 font-bold uppercase tracking-widest">Financeiro 2026</p>
                </div>
            </div>
        </div>
    </aside>

    <main class="flex-1 flex flex-col min-w-0 bg-[#050B18]">
        <header class="h-20 border-b border-white/5 flex items-center justify-between px-10 bg-[#09162E]/50 backdrop-blur-md shrink-0">
            <h2 id="header-title" class="text-xl font-bold text-white uppercase font-condensed tracking-wider">Painel Executivo</h2>
            <div class="text-right">
                <span class="text-[10px] text-slate-500 font-bold uppercase tracking-widest block">Última Actualização</span>
                <span class="text-sm font-bold text-[#3DB8E8]">13 de Maio de 2026</span>
            </div>
        </header>

        <div class="flex-1 overflow-y-auto p-10">
            
            <!-- TAB: DASHBOARD -->
            <div id="tab-dashboard" class="tab-content active space-y-8">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6">
                    <div class="glass-card p-6 border-t-4 border-[#3DB8E8]">
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Total Esperado</p>
                        <h3 class="text-3xl font-bold text-white font-condensed">R$ 38.340</h3>
                        <p class="text-[9px] text-slate-500 mt-2 italic font-semibold">Base: 46 Atletas</p>
                    </div>
                    <div class="glass-card p-6 border-t-4 border-[#22D07A]">
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Já Recebido</p>
                        <h3 class="text-3xl font-bold text-[#22D07A] font-condensed" id="kpi-recebido">R$ 12.380</h3>
                        <p class="text-[9px] text-slate-500 mt-2 font-bold">32.3% Arrecadado</p>
                    </div>
                    <div class="glass-card p-6 border-t-4 border-[#3DB8E8]">
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">A Receber</p>
                        <h3 class="text-3xl font-bold text-[#3DB8E8] font-condensed">R$ 13.960</h3>
                        <p class="text-[9px] text-slate-500 mt-2 font-bold">Saldo Planos Ativos</p>
                    </div>
                    <div class="glass-card p-6 border-t-4 border-[#8B5CF6]">
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Taxas de Jogo</p>
                        <h3 class="text-3xl font-bold text-[#A78BFA] font-condensed">R$ 12.000</h3>
                        <p class="text-[9px] text-slate-500 mt-2 font-bold uppercase tracking-tighter">Projeção 3 Gamedays</p>
                    </div>
                    <div class="glass-card p-6 border-t-4 border-[#F04F4F]">
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Em Risco</p>
                        <h3 class="text-3xl font-bold text-[#F04F4F] font-condensed">R$ 4.560</h3>
                        <p class="text-[9px] text-red-500/60 mt-2 font-bold uppercase tracking-tighter italic">Após Desligamentos</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    <div class="glass-card p-8">
                        <h4 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-8">Composição do Total (R$ 38.340)</h4>
                        <div class="space-y-10">
                            <div>
                                <div class="flex justify-between mb-2">
                                    <span class="text-xs font-bold text-white uppercase tracking-wider">Receita de Planos</span>
                                    <span class="text-sm font-bold text-[#3DB8E8]">R$ 26.340 (68.7%)</span>
                                </div>
                                <div class="w-full bg-white/5 h-3 rounded-full overflow-hidden">
                                    <div class="bg-[#3DB8E8] h-full" style="width: 68.7%"></div>
                                </div>
                            </div>
                            <div>
                                <div class="flex justify-between mb-2">
                                    <span class="text-xs font-bold text-white uppercase tracking-wider">Taxas e Permutas</span>
                                    <span class="text-sm font-bold text-[#A78BFA]">R$ 12.000 (31.3%)</span>
                                </div>
                                <div class="w-full bg-white/5 h-3 rounded-full overflow-hidden">
                                    <div class="bg-[#8B5CF6] h-full" style="width: 31.3%"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="glass-card p-8 flex flex-col justify-center text-center">
                        <div class="flex items-center justify-around gap-4">
                            <div class="flex flex-col items-center">
                                <span class="text-4xl font-bold text-white font-condensed">46</span>
                                <span class="text-[10px] text-slate-500 uppercase font-bold tracking-widest">Elenco Total</span>
                            </div>
                            <div class="w-px h-16 bg-white/5"></div>
                            <div class="flex flex-col items-center">
                                <span class="text-4xl font-bold text-[#22D07A] font-condensed">33</span>
                                <span class="text-[10px] text-slate-500 uppercase font-bold tracking-widest">OK Adimplentes</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TAB: ATLETAS -->
            <div id="tab-atletas" class="tab-content space-y-6">
                <div class="flex flex-col gap-6">
                    <div class="flex flex-wrap items-center justify-between gap-4">
                        <div class="flex flex-wrap gap-2" id="athleteFilters">
                            <button onclick="setStatusFilter('ALL', this)" class="px-4 py-2 bg-[#3DB8E8] text-[#09162E] text-[10px] font-bold uppercase rounded filter-btn-active transition-all">Todos</button>
                            <button onclick="setStatusFilter('OK', this)" class="px-4 py-2 bg-emerald-500/10 text-emerald-500 text-[10px] font-bold uppercase rounded border border-emerald-500/20 hover:bg-emerald-500/30 transition-all">OK</button>
                            <button onclick="setStatusFilter('NOK', this)" class="px-4 py-2 bg-red-500/10 text-red-500 text-[10px] font-bold uppercase rounded border border-red-500/20 hover:bg-red-500/30 transition-all">Atrasos (NOK)</button>
                            <button onclick="setStatusFilter('NEG', this)" class="px-4 py-2 bg-amber-500/10 text-amber-500 text-[10px] font-bold uppercase rounded border border-amber-500/20 hover:bg-amber-500/30 transition-all">Negociação</button>
                            <button onclick="setStatusFilter('NOVO', this)" class="px-4 py-2 bg-purple-500/10 text-purple-500 text-[10px] font-bold uppercase rounded border border-purple-500/20 hover:bg-purple-500/30 transition-all">Transição</button>
                        </div>
                        <div class="relative w-full md:w-64">
                            <i class="fa-solid fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-500"></i>
                            <input type="text" id="athleteSearch" placeholder="Nome ou posição..." class="w-full bg-[#0E1F42] border border-white/10 rounded-lg py-2 pl-12 pr-4 text-sm focus:border-[#3DB8E8] outline-none">
                        </div>
                    </div>
                    <div class="flex items-center gap-4 bg-black/20 p-4 rounded-xl border border-white/5">
                        <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest shrink-0"><i class="fa-solid fa-filter mr-2"></i>Filtrar Posição:</span>
                        <select id="positionSelect" onchange="setPosFilter(this.value)" class="filter-select bg-[#09162E] border border-white/10 text-[#3DB8E8] text-[10px] font-bold uppercase rounded px-4 py-2 outline-none focus:border-[#3DB8E8] min-w-[150px]">
                            <option value="ALL">Todas as Posições</option>
                            <option value="DB">Defensive Backs (DB)</option>
                            <option value="DL">Defensive Line (DL)</option>
                            <option value="LB">Linebackers (LB)</option>
                            <option value="OL">Offensive Line (OL)</option>
                            <option value="QB">Quarterbacks (QB)</option>
                            <option value="RB">Running Backs (RB)</option>
                            <option value="WR/TE">WR / Tight Ends</option>
                            <option value="K/P">Kicker / Punter</option>
                        </select>
                        <div id="resultsCount" class="text-[10px] font-bold text-[#3DB8E8] uppercase bg-[#3DB8E8]/10 px-3 py-1 rounded-full ml-auto tracking-widest">46 Atletas</div>
                    </div>
                </div>

                <div class="glass-card overflow-hidden">
                    <table class="w-full text-left" id="athletesTable">
                        <thead class="bg-black/20 border-b border-white/5">
                            <tr>
                                <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest">Atleta</th>
                                <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase">Pos</th>
                                <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase">Plano</th>
                                <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase text-right tracking-widest">Anual</th>
                                <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase">Status</th>
                                <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase text-center tracking-widest">✨ AI Assist</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5" id="athleteListBody"></tbody>
                    </table>
                </div>
            </div>

            <!-- TAB: FINANCEIRO -->
            <div id="tab-financeiro" class="tab-content space-y-8">
                <div class="glass-card p-10">
                    <div class="flex justify-between items-center mb-12">
                        <h3 class="text-xl font-bold text-white uppercase font-condensed tracking-wide">Projeção Mensal de Entrada (MAR–DEZ 2026)</h3>
                        <div class="flex gap-4">
                             <div class="flex items-center gap-2"><div class="w-3 h-3 bg-[#22D07A] opacity-60 rounded-sm"></div><span class="text-[9px] font-bold uppercase tracking-widest text-slate-500">Histórico</span></div>
                             <div class="flex items-center gap-2"><div class="w-3 h-3 bg-[#3DB8E8] rounded-sm"></div><span class="text-[9px] font-bold uppercase tracking-widest text-slate-500">Mensalidades</span></div>
                             <div class="flex items-center gap-2"><div class="w-3 h-3 bg-[#8B5CF6] rounded-sm"></div><span class="text-[9px] font-bold uppercase tracking-widest text-slate-500">Taxas Jogo</span></div>
                        </div>
                    </div>
                    
                    <div class="chart-container border-b border-white/10">
                        <div class="chart-bar-group group relative"><div class="bar-past" style="height: 100%;"></div><span class="text-[9px] font-bold text-slate-500 mt-4 block text-center uppercase">Mar</span></div>
                        <div class="chart-bar-group group relative"><div class="bar-past" style="height: 43%;"></div><span class="text-[9px] font-bold text-slate-500 mt-4 block text-center uppercase">Abr</span></div>
                        <div class="chart-bar-group group relative"><div class="bar-plan" style="height: 34%;"></div><span class="text-[9px] font-bold text-slate-300 mt-4 block text-center uppercase">Mai</span></div>
                        <div class="chart-bar-group group relative"><div class="bar-plan" style="height: 25%;"></div><span class="text-[9px] font-bold text-slate-500 mt-4 block text-center uppercase">Jun</span></div>
                        <div class="chart-bar-group group relative"><div class="bar-taxa" style="height: 54.8%;"></div><div class="bar-plan" style="height: 45.2%;"></div><span class="text-[9px] font-bold text-[#3DB8E8] mt-4 block text-center uppercase">Jul [J]</span></div>
                        <div class="chart-bar-group group relative"><div class="bar-taxa" style="height: 68.3%;"></div><div class="bar-plan" style="height: 31.7%;"></div><span class="text-[9px] font-bold text-[#3DB8E8] mt-4 block text-center uppercase">Ago [J]</span></div>
                        <div class="chart-bar-group group relative"><div class="bar-plan" style="height: 55.4%;"></div><span class="text-[9px] font-bold text-slate-500 mt-4 block text-center uppercase">Set</span></div>
                        <div class="chart-bar-group group relative"><div class="bar-taxa" style="height: 69.5%;"></div><div class="bar-plan" style="height: 30.5%;"></div><span class="text-[9px] font-bold text-[#3DB8E8] mt-4 block text-center uppercase">Out [J]</span></div>
                        <div class="chart-bar-group group relative"><div class="bar-plan" style="height: 22%;"></div><span class="text-[9px] font-bold text-slate-500 mt-4 block text-center uppercase">Nov</span></div>
                        <div class="chart-bar-group group relative"><div class="bar-plan" style="height: 22%;"></div><span class="text-[9px] font-bold text-slate-500 mt-4 block text-center uppercase">Dez</span></div>
                    </div>
                </div>

                <div class="glass-card overflow-hidden">
                    <table class="w-full text-left">
                        <thead class="bg-black/10">
                            <tr>
                                <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest">Mês/Período</th>
                                <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase text-right tracking-widest">Previsto</th>
                                <th class="px-6 py-4 text-[10px] font-bold text-[#22D07A] uppercase text-right tracking-widest">Recebido</th>
                                <th class="px-6 py-4 text-[10px] font-bold text-[#3DB8E8] uppercase text-right tracking-widest">Saldo</th>
                                <th class="px-6 py-4 text-[10px] font-bold text-slate-500 uppercase tracking-widest text-center">Natureza</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5" id="monthlyListBody"></tbody>
                    </table>
                </div>
            </div>

            <!-- TAB: PAGAMENTOS -->
            <div id="tab-pagamentos" class="tab-content space-y-6">
                <div class="flex flex-wrap items-center justify-between gap-4 mb-2">
                    <span class="text-[10px] font-bold text-[#3DB8E8] uppercase bg-[#3DB8E8]/10 px-3 py-1.5 rounded border border-[#3DB8E8]/20 tracking-widest">Liquidez Ativa</span>
                    <div class="relative w-full md:w-80">
                        <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-slate-500"></i>
                        <input type="text" id="paymentSearch" oninput="renderPayments()" placeholder="Procurar atleta..." class="w-full bg-[#0E1F42] border border-white/10 rounded-lg py-2 pl-12 pr-4 text-sm focus:border-[#3DB8E8] outline-none">
